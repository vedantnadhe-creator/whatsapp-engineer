        </mxCell>
        <mxCell id="legend_text" value="&lt;font style=&quot;font-size:11px&quot;&gt;1. User sends WhatsApp msg → Baileys bridge → Main Router&lt;br&gt;2. Router → Orchestrator → Gemini classifies intent → returns Action&lt;br&gt;3. Router → Claude Manager → spawns Claude Code CLI via PTY&lt;br&gt;4. Claude reads KB, edits code, streams JSON events back&lt;br&gt;5. Events → Router → broadcast reply via WhatsApp&lt;br&gt;6. Dashboard provides alternative web interface to same engine&lt;br&gt;7. Cron Manager triggers scheduled tasks independently&lt;/font&gt;" style="text;html=1;fontSize=11;align=left;verticalAlign=top;fillColor=none;strokeColor=none;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="55" y="1055" width="470" height="90" as="geometry" />
        </mxCell>

        <!-- ==================== TWO-STAGE LLM LABEL ==================== -->

        <mxCell id="two_stage" value="&lt;b&gt;Two-Stage LLM Architecture&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;Stage 1: Gemini (fast, cheap) → intent routing&lt;br&gt;Stage 2: Claude Code (powerful) → code execution&lt;/font&gt;" style="shape=callout;whiteSpace=wrap;html=1;perimeter=calloutPerimeter;size=20;position=0.5;position2=1;base=30;fillColor=#fff2cc;strokeColor=#d6b656;shadow=0;fontSize=12;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="780" y="545" width="280" height="80" as="geometry" />
        </mxCell>

        <!-- WhatsApp Auth Info -->
        <mxCell id="auth_info" value="&lt;font style=&quot;font-size:10px&quot;&gt;auth_info/&lt;br&gt;(Baileys creds)&lt;/font&gt;" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=0.15;fillColor=#f5f5f5;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="310" y="320" width="90" height="50" as="geometry" />
        </mxCell>

        <!-- Arrow: WhatsApp Bridge → auth_info -->
        <mxCell id="e_wa_auth" style="rounded=1;strokeWidth=1;strokeColor=#999999;dashed=1;" edge="1" source="wa_bridge" target="auth_info" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- SQLite DB file -->
        <mxCell id="db_file" value="&lt;font style=&quot;font-size:10px&quot;&gt;sessions.db&lt;br&gt;(SQLite + WAL)&lt;/font&gt;" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=0.15;fillColor=#e6d0de;strokeColor=#996185;" vertex="1" parent="1">
          <mxGeometry x="1080" y="650" width="100" height="50" as="geometry" />
        </mxCell>

        <!-- Arrow: Session Store → DB file -->
        <mxCell id="e_store_db" style="rounded=1;strokeWidth=1;strokeColor=#996185;dashed=1;" edge="1" source="session_store" target="db_file" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
