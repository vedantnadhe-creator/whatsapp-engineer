        <mxCell id="legend_title" value="&lt;b&gt;Data Flow Summary&lt;/b&gt;" style="text;html=1;fontSize=13;fontStyle=0;align=left;verticalAlign=top;fillColor=none;strokeColor=none;" vertex="1" parent="1">
