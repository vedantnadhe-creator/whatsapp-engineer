# WhatsApp AI Engineer — Environment Variables
# Copy this file to .env and fill in your values.
# Or run: bash setup.sh (interactive wizard)

# === Core ===
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3-flash-preview
CLAUDE_BIN=/home/ubuntu/.local/bin/claude

# Deepgram — speech-to-text (/api/transcribe) + text-to-speech (voice orchestrator)
DEEPGRAM_API_KEY=your_deepgram_api_key_here
DEEPGRAM_TTS_MODEL=aura-2-thalia-en

# === Access Control ===
# Comma-separated WhatsApp numbers with country code (no +)
ALLOWED_PHONES=919970000000

# === Auth (JWT + Email OTP) ===
# Generate a strong random string for JWT_SECRET!
JWT_SECRET=change-me-to-a-long-random-string

# SMTP credentials for sending OTP emails (Gmail example below)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# === Paths ===
DEFAULT_WORKING_DIR=/home/ubuntu
DB_PATH=./sessions.db
AUTH_DIR=./auth_info
LOG_DIR=./logs

# === Optional: Knowledge Base ===
# GITHUB_KB_URL=https://github.com/your-org/knowledge-base.git
# KB_DIR=./kb

# === Optional: Google Sheets (Sprint Board "Open in Sheet" / Template) ===
# Service-account auth. Enable the Google Sheets API + Drive API on the project.
# Provide ONE of these:
#   GOOGLE_SERVICE_ACCOUNT_FILE=/home/ubuntu/whatsapp-engineer/google-sa.json
#   GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Optional: also share new sheets with this email and/or place them in a Drive
# folder (use a Shared Drive folder so the service account can own the file).
# GOOGLE_SHEETS_SHARE_WITH=team@yourcompany.com
# GOOGLE_DRIVE_FOLDER_ID=0AbCdEf...
# If unset, "Open in Sheet"/"Template" fall back to generating an .xlsx download.
